            <inertial pos="0.00548 -0.000975 -0.115" mass="0.154" diaginertia="0.000374318 0.000375772 2.5785e-05"/>
            <geom type="capsule" size="0.025 0.1" pos="0 0 -0.1" rgba="0.4 0.4 0.6 1"/>
            <body name="FL_foot" pos="0 0 -0.213">
