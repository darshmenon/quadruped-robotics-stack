<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="go2_rl">

    <physics name="1ms" type="ode">
      <max_step_size>0.005</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"/>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Flat spawn/reset area at the origin. stand_go2_gz.py hardcodes the
         fall-recovery reset pose to (0,0,0.32) in this world, so the origin
         must stay flat ground. All terrain features below are offset along
         +X, away from the origin. -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>200 200</size></plane></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>200 200</size></plane></geometry>
          <material><ambient>0.8 0.8 0.8 1</ambient><diffuse>0.8 0.8 0.8 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Ramps (x ~ 2.5-5.5m): two lanes, 12 deg and 22 deg, rising toward +X -->
    <model name="ramp_12deg">
      <static>true</static>
      <pose>4 -2 0.3608 0 -0.2094 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>3 2 0.1</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
        </collision>
        <visual name="visual">
          <geometry><box><size>3 2 0.1</size></box></geometry>
          <material><ambient>0.6 0.6 0.7 1</ambient><diffuse>0.6 0.6 0.7 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="ramp_22deg">
      <static>true</static>
      <pose>4 2 0.6083 0 -0.3840 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>3 2 0.1</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
        </collision>
        <visual name="visual">
          <geometry><box><size>3 2 0.1</size></box></geometry>
          <material><ambient>0.7 0.5 0.5 1</ambient><diffuse>0.7 0.5 0.5 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Staircase (x ~ 8-9.5m): 6 steps, 0.08m rise x 0.25m run -->
    <model name="staircase">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="step_1">
        <pose>8.125 0 0.04 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.25 2 0.08</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.25 2 0.08</size></box></geometry>
          <material><ambient>0.55 0.55 0.55 1</ambient><diffuse>0.55 0.55 0.55 1</diffuse></material></visual>
      </link>
      <link name="step_2">
        <pose>8.375 0 0.08 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.25 2 0.16</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.25 2 0.16</size></box></geometry>
          <material><ambient>0.55 0.55 0.55 1</ambient><diffuse>0.55 0.55 0.55 1</diffuse></material></visual>
      </link>
      <link name="step_3">
        <pose>8.625 0 0.12 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.25 2 0.24</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.25 2 0.24</size></box></geometry>
          <material><ambient>0.55 0.55 0.55 1</ambient><diffuse>0.55 0.55 0.55 1</diffuse></material></visual>
      </link>
      <link name="step_4">
        <pose>8.875 0 0.16 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.25 2 0.32</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.25 2 0.32</size></box></geometry>
          <material><ambient>0.55 0.55 0.55 1</ambient><diffuse>0.55 0.55 0.55 1</diffuse></material></visual>
      </link>
      <link name="step_5">
        <pose>9.125 0 0.2 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.25 2 0.4</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.25 2 0.4</size></box></geometry>
          <material><ambient>0.55 0.55 0.55 1</ambient><diffuse>0.55 0.55 0.55 1</diffuse></material></visual>
      </link>
      <link name="step_6">
        <pose>9.375 0 0.24 0 0 0</pose>
        <collision name="collision"><geometry><box><size>0.25 2 0.48</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.25 2 0.48</size></box></geometry>
          <material><ambient>0.55 0.55 0.55 1</ambient><diffuse>0.55 0.55 0.55 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Rough patch (x ~ 14-18m): grid of small boxes with smoothly
         varying heights, generated by scripts/generate_rough_patch.py.
