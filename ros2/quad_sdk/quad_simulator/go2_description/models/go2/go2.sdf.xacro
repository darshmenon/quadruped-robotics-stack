    </frame>
    <frame name='lower2_rotor' attached_to='lower2_rotor_joint'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    <frame name='lower2_lower1_joint' attached_to='lower2_lower'>
      <pose>-0.01 0 -0.040000000000000001 0 0.4800000000000002 0</pose>
    </frame>
    <frame name='lower2_lower1' attached_to='lower2_lower1_joint'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    <frame name='lower2_lower_joint' attached_to='lower2'>
      <pose>0.02 0 -0.14799999999999999 0 0.050000000000000003 0</pose>
    </frame>
    <frame name='lower2_lower' attached_to='lower2_lower_joint'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    <frame name='foot2_joint' attached_to='lower2'>
      <pose>0 0 -0.21299999999999999 0 0 0</pose>
    </frame>
    <frame name='foot2' attached_to='foot2_joint'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    <frame name='upper1_rotor_joint' attached_to='hip1'>
      <pose>0 -0.00014999999999999999 0 0 0 0</pose>
    </frame>
    <frame name='upper1_rotor' attached_to='upper1_rotor_joint'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    <frame name='lower1_rotor_joint' attached_to='upper1'>
      <pose>0 -0.032349999999999997 0 0 0 0</pose>
    </frame>
    <frame name='lower1_rotor' attached_to='lower1_rotor_joint'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    <frame name='lower1_lower1_joint' attached_to='lower1_lower'>
      <pose>-0.01 0 -0.040000000000000001 0 0.4800000000000002 0</pose>
    </frame>
    <frame name='lower1_lower1' attached_to='lower1_lower1_joint'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    <frame name='lower1_lower_joint' attached_to='lower1'>
      <pose>0.02 0 -0.14799999999999999 0 0.050000000000000003 0</pose>
    </frame>
    <frame name='lower1_lower' attached_to='lower1_lower_joint'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    <frame name='foot1_joint' attached_to='lower1'>
      <pose>0 0 -0.21299999999999999 0 0 0</pose>
    </frame>
    <frame name='foot1' attached_to='foot1_joint'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    <frame name='upper3_rotor_joint' attached_to='hip3'>
      <pose>0 0.00014999999999999999 0 0 0 0</pose>
    </frame>
    <frame name='upper3_rotor' attached_to='upper3_rotor_joint'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    <frame name='lower3_rotor_joint' attached_to='upper3'>
      <pose>0 0.032349999999999997 0 0 0 0</pose>
    </frame>
    <frame name='lower3_rotor' attached_to='lower3_rotor_joint'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    <frame name='lower3_lower1_joint' attached_to='lower3_lower'>
      <pose>-0.01 0 -0.040000000000000001 0 0.4800000000000002 0</pose>
    </frame>
    <frame name='lower3_lower1' attached_to='lower3_lower1_joint'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    <frame name='lower3_lower_joint' attached_to='lower3'>
      <pose>0.02 0 -0.14799999999999999 0 0.050000000000000003 0</pose>
    </frame>
    <frame name='lower3_lower' attached_to='lower3_lower_joint'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    <frame name='foot3_joint' attached_to='lower3'>
      <pose>0 0 -0.21299999999999999 0 0 0</pose>
    </frame>
    <frame name='foot3' attached_to='foot3_joint'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    <!-- Publish imu sensor readings -->
    <include>
      <uri>model://imu</uri>
      <name>imu</name>
      <pose>0 0 0 0 0 0 </pose>
    </include>

    <joint name="imu_joint" type="fixed">
      <child>imu::link</child>
      <parent>body</parent>
    </joint>

    <!-- Setup ros control -->
    <plugin
        filename="libgz_ros2_control-system.so"
        name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <controlPeriod>0.001</controlPeriod>
        <parameters>$(arg controller_config_path)</parameters>
            <ros>
              <namespace>$(arg namespace)</namespace>
          </ros>
    </plugin>

    <!-- Pin the body at its spawn pose for hold_duration seconds so that
         controllers can come up and fold the legs into sit pose without
         the body tipping. Joints articulate freely the whole time. The
         plugin tracks both sim-time and wall-clock elapsed since first
         PreUpdate; whichever crosses hold_duration first triggers the
         release. The wall-clock fallback exists because — under load —
         gz-sim's sim-time can stall on individual plugin instances and
         the sim-time-only check would freeze the body indefinitely. -->
    <plugin filename="libspawn_lock.so" name="spawn_lock">
        <body_link>body</body_link>
        <hold_duration>8.0</hold_duration>
    </plugin>

    <!-- Publish ground truth state data -->
    <plugin filename="libground_truth_estimator.so" name="ground_truth_estimator">
      <updateRateHZ>500.0</updateRateHZ>
      <ground_truth_state_topic>state/ground_truth</ground_truth_state_topic>
      <ground_truth_body_frame_topic>state/ground_truth_body_frame</ground_truth_body_frame_topic>
      <parameters>$(arg controller_config_path)</parameters>
      <ros>
        <parameter name="use_sim_time">true</parameter>
      </ros>
    </plugin>
  </model>
</sdf>
