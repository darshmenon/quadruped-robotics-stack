<CycloneDDS>
    <!-- ROS 2 domain: communicate with remote computer over the 192.168.8.0/24 subnet.
         ROBOT_ROS_IP is set by init_robot.sh based on whichever interface has
         an address on that subnet, so this survives DHCP renewals and dongle swaps. -->
    <Domain Id="42">
        <General>
            <Interfaces>
                <NetworkInterface address="${ROBOT_ROS_IP}"/>
            </Interfaces>
            <AllowMulticast>false</AllowMulticast>
            <DontRoute>true</DontRoute>
            <MaxMessageSize>65500B</MaxMessageSize>
        </General>
        <Internal>
            <SocketReceiveBufferSize min="128MB"/>
            <SocketSendBufferSize min="128MB"/>
            <Watermarks>
                <WhcHigh>500kB</WhcHigh>
            </Watermarks>
            <FragmentSize>1452B</FragmentSize>
        </Internal>
        <Discovery>
            <Peers>
                <Peer address="192.168.8.103"/>
            </Peers>
            <ParticipantIndex>auto</ParticipantIndex>
        </Discovery>
    </Domain>

    <!-- Unitree SDK domain: communicate with MCU (192.168.123.161) over the
         192.168.123.0/24 subnet. ROBOT_MCU_IP is set by init_robot.sh. -->
    <Domain Id="0">
        <General>
            <Interfaces>
                <NetworkInterface address="${ROBOT_MCU_IP}"/>
            </Interfaces>
        </General>
        <Discovery>
            <ParticipantIndex>auto</ParticipantIndex>
        </Discovery>
    </Domain>
</CycloneDDS>
