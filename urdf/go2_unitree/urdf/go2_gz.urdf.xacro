<?xml version="1.0"?>
<robot name="go2_description" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Include base go2 URDF -->
  <xacro:include filename="$(find champ_description)/urdf/go2.urdf"/>

  <!-- 5-DOF manipulator arm mounted on top of the body, forward of center
       and above the base collision box (0.3762 x 0.0935 x 0.114, top face
       at z=0.057) so it doesn't intersect the body mesh -->
  <xacro:include filename="$(find champ_description)/urdf/arm.urdf.xacro"/>
  <xacro:champ_arm parent="base">
    <origin rpy="0 0 0" xyz="0.08 0 0.057"/>
  </xacro:champ_arm>

  <!-- Gazebo Harmonic gz_ros2_control plugin -->
  <gazebo>
    <plugin filename="libgz_ros2_control-system.so"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find training)/config/go2_ros2_control.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- ros2_control hardware interface -->
  <ros2_control name="go2_gz" type="system">
    <hardware>
      <plugin>gz_ros2_control/GzSystem</plugin>
    </hardware>
    <joint name="FL_hip_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.1</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FL_thigh_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.8</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FL_calf_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">-1.5</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FR_hip_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">-0.1</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FR_thigh_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.8</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FR_calf_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">-1.5</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RL_hip_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.1</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RL_thigh_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">1.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RL_calf_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">-1.5</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RR_hip_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">-0.1</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RR_thigh_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">1.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RR_calf_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">-1.5</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="base_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lower_arm_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="upper_arm_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wrist1_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wrist2_joint">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- IMU sensor on base -->
  <gazebo reference="base">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>200</update_rate>
      <topic>/imu/data</topic>
      <gz_frame_id>base</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- LiDAR sensor on base -->
  <gazebo reference="base">
    <sensor name="lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <topic>scan</topic>
      <gz_frame_id>base</gz_frame_id>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>10.0</max>
          <resolution>0.015</resolution>
        </range>
      </ray>
    </sensor>
  </gazebo>

</robot>
